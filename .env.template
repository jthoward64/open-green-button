# ── Open Green Button — local secrets for the ESPI onboarding driver ──────────────────────────
#
# Copy to `.env` (gitignored) and fill in. Consumed by:
#   ./gradlew :app:onboardFetchAppInfo --args="<utilityId>"
#
# Keys are utility-specific so the same driver serves every utility we onboard. The prefix is
#   OPENGB_ONBOARD_<ID>_...   where <ID> = the utility id upper-cased  (milton_hydro → MILTON_HYDRO)
#
# The values below are the initial *registration* credentials + endpoints the Data Custodian gave
# you at application submission — NOT the client_id/client_secret we discover from the
# ApplicationInformation resource (that's this driver's output).

# ── Milton Hydro (savagedata sandbox DC) ──────────────────────────────────────────────────────

# Data Custodian OAuth2 token endpoint (client_credentials → registration_access_token).
OPENGB_ONBOARD_MILTON_HYDRO_TOKEN_URL=https://sandboxdc.savagedata.com:4243/connect/token

# ApplicationInformation resource URL — captured from the notification (log field notify.resources).
OPENGB_ONBOARD_MILTON_HYDRO_APP_INFO_URL=https://sandboxdc.savagedata.com:4243/espi/1_1/resource/ApplicationInformation/3eba029d-80f1-5bff-9dd0-3ab993ce1ef6

# Initial registration client credentials (from savagedata at registration).
OPENGB_ONBOARD_MILTON_HYDRO_REG_CLIENT_ID=
OPENGB_ONBOARD_MILTON_HYDRO_REG_CLIENT_SECRET=

# Optional grant scope for the client_credentials call. Leave blank to omit `scope` entirely; if
# the token endpoint rejects the request, try the scope savagedata specified.
OPENGB_ONBOARD_MILTON_HYDRO_REG_SCOPE=

# Optional: how client creds are presented to the token endpoint — HTTP_BASIC (default) or FORM_BODY.
#OPENGB_ONBOARD_MILTON_HYDRO_TOKEN_AUTH_STYLE=HTTP_BASIC

# mTLS client certificate presented to the DC (savagedata requires a non-self-signed leaf cert).
# Base64 of the PKCS12 keystore bytes:  base64 -w0 client.p12
OPENGB_ONBOARD_MILTON_HYDRO_CLIENTAUTH_KEYSTORE_BASE64=
OPENGB_ONBOARD_MILTON_HYDRO_CLIENTAUTH_KEYSTORE_PASSWORD=
# Optional keystore tweaks:
#OPENGB_ONBOARD_MILTON_HYDRO_CLIENTAUTH_KEYSTORE_TYPE=PKCS12
#OPENGB_ONBOARD_MILTON_HYDRO_CLIENTAUTH_KEY_ALIAS=
#OPENGB_ONBOARD_MILTON_HYDRO_CLIENTAUTH_KEY_PASSWORD=

# ── Direct usage-resource diagnostic (onboardFetchUsageDirect) ─────────────────────────────────
# Only needed to run `./gradlew :app:onboardFetchUsageDirect` (hits savagedata's Subscription
# resource directly for a redeemed claim). These are PRODUCTION Fly secrets — read them off the
# running machine (Fly secrets are write-only via `fly secrets`, but are injected as env vars):
#   fly -a open-green-button ssh console -C 'printenv OPENGB_CRYPTO_AESKEYBASE64'
#   fly -a open-green-button ssh console -C 'printenv OPENGB_UTILITY_MILTON_HYDRO_CLIENTSECRET'
# The AES key decrypts EVERY user's refresh blob — keep this .env local and gitignored (it is).
OPENGB_CRYPTO_AESKEYBASE64=
OPENGB_UTILITY_MILTON_HYDRO_CLIENTSECRET=
